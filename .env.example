# =============================================================================
# Polla Mundialista — Environment Template
# Copy this file to .env and fill in real values. NEVER commit .env.
# Generate secrets with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# =============================================================================

# --- Supabase database URLs --------------------------------------------------
# Find your project ref in: https://supabase.com/dashboard/project/<ref>/settings/database
# Each service uses its own PostgreSQL schema for isolation.
# Format: postgresql://postgres.<PROJECT_REF>:<DB_PASSWORD>@<POOLER_HOST>:5432/postgres?schema=<SCHEMA>

AUTH_DATABASE_URL=postgresql://postgres.YOUR_PROJECT_REF:YOUR_DB_PASSWORD@aws-1-us-east-1.pooler.supabase.com:5432/postgres?schema=worldcup_auth
MATCHES_DATABASE_URL=postgresql://postgres.YOUR_PROJECT_REF:YOUR_DB_PASSWORD@aws-1-us-east-1.pooler.supabase.com:5432/postgres?schema=worldcup_matches
PREDICTIONS_DATABASE_URL=postgresql://postgres.YOUR_PROJECT_REF:YOUR_DB_PASSWORD@aws-1-us-east-1.pooler.supabase.com:5432/postgres?schema=worldcup_predictions

# --- Auth --------------------------------------------------------------------

# Min 32 chars random string — node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=CHANGE_ME_strong_random_secret_min_32_chars
# Min 32 chars random string — same command as above
JWT_REFRESH_SECRET=CHANGE_ME_different_random_secret_min_32_chars
# Comma-separated list of emails that get admin role on first login
ADMIN_EMAILS=admin@yourdomain.com,otro@yourdomain.com

# --- Google OAuth ------------------------------------------------------------
# Create a project at https://console.cloud.google.com/
# Enable the "Google Identity" API, create OAuth 2.0 Web Client credentials.
# Add https://minuto90.site to Authorised JavaScript origins.
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com
# Frontend also needs this (same value, prefixed with VITE_)
VITE_GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com

# --- API-Football ------------------------------------------------------------
# Get your key at https://dashboard.api-sports.io/
FOOTBALL_DATA_API_KEY=YOUR_FOOTBALL_DATA_API_KEY
FOOTBALL_COMPETITION=WC
FOOTBALL_SEASON=2026

# --- Inter-service communication ---------------------------------------------

AUTH_SERVICE_URL=http://worldcup-auth-service:3001
MATCHES_SERVICE_URL=http://worldcup-matches-service:3002
PREDICTIONS_SERVICE_URL=http://worldcup-predictions-service:3003

# Min 32 chars random string — different from JWT secrets
INTERNAL_SERVICE_TOKEN=CHANGE_ME_random_internal_token

# --- Frontend ----------------------------------------------------------------
# Must be set — no wildcard fallback
# Development:  FRONTEND_URL=http://localhost:5173
# Production:   FRONTEND_URL=https://minuto90.site
FRONTEND_URL=https://minuto90.site

# --- Let's Encrypt -----------------------------------------------------------
# Email for expiry notifications (used by init-letsencrypt.sh)
LETSENCRYPT_EMAIL=admin@minuto90.site

# --- Service ports -----------------------------------------------------------

AUTH_SERVICE_PORT=3001
MATCHES_SERVICE_PORT=3002
PREDICTIONS_SERVICE_PORT=3003

# --- Logging ----------------------------------------------------------------
LOG_LEVEL=info   # trace | debug | info | warn | error
