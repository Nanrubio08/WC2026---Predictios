generator client {
  provider      = "prisma-client-js"
  output        = "../src/generated/client"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum MatchStatus {
  scheduled
  live
  finished
}

model Match {
  id               Int         @id
  homeTeam         String      @map("home_team")
  awayTeam         String      @map("away_team")
  homeLogoUrl      String?     @map("home_logo_url")
  awayLogoUrl      String?     @map("away_logo_url")
  kickoffTime      DateTime    @map("kickoff_time")
  homeScoreActual  Int?        @map("home_score_actual")
  awayScoreActual  Int?        @map("away_score_actual")
  status           MatchStatus @default(scheduled)
  stage            String?
  group            String?
  matchday         Int?
  updatedAt        DateTime    @updatedAt @map("updated_at")

  @@map("matches")
}

model AdminAuditLog {
  id            String   @id @default(uuid())
  adminUserId   String   @map("admin_user_id")
  service       String   @default("matches")
  action        String
  matchId       Int?     @map("match_id")
  previousHome  Int?     @map("previous_home")
  previousAway  Int?     @map("previous_away")
  newHome       Int?     @map("new_home")
  newAway       Int?     @map("new_away")
  detail        String?  // JSON string for non-match audit context
  createdAt     DateTime @default(now()) @map("created_at")

  @@map("admin_audit_log")
}
